# Variables d'environnement attendues par la suite de tests.
# Copier ce fichier en `.env` et adapter les valeurs pour le local.
# En CI, ces variables sont fournies par le workflow (pas de fichier .env).

# URL de base de la plateforme testee
BASE_URL=http://localhost:8000

# Compte de service utilise pour le login mutualise
SERVICE_EMAIL=eleve.test@codeunmax.fr
SERVICE_PASSWORD=Test1234!

# Seed Faker pour des donnees reproductibles
FAKER_SEED=12345

# Mode navigateur (1 = headless, 0 = fenetre visible pour debug)
HEADLESS=1
